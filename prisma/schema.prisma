// Urvar Natural CRM — Prisma 7 schema
// Generator uses the new `prisma-client` provider (Prisma 7) with an explicit output.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  SALES_MANAGER
  SALES_EXECUTIVE
  DISTRIBUTOR_MANAGER
  ACCOUNTS_TEAM
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  FOLLOW_UP
  QUOTATION_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  META_ADS
  GOOGLE_ADS
  TRADE_SHOW
  REFERRAL
  DISTRIBUTOR
  DIRECT_CALL
  WHATSAPP
  ORGANIC_SEARCH
  GOVERNMENT_TENDER
  OTHER
}

enum CustomerType {
  B2C_FARMER
  B2B_RETAILER
  B2B_DEALER
  B2B_DISTRIBUTOR
  AGRI_INPUT_SHOP
  FPO_COOPERATIVE
  NGO
  GOVERNMENT
  CORPORATE_FARM
  PLANTATION
}

enum DealerTier {
  GOLD
  SILVER
  BRONZE
}

enum PipelineStage {
  NEW_LEAD
  FIRST_CONTACT
  REQUIREMENT_GATHERING
  PRODUCT_DISCUSSION
  SAMPLE_SENT
  QUOTATION_SENT
  NEGOTIATION
  ORDER_RECEIVED
  WON
  LOST
}

enum ActivityType {
  NOTE
  STATUS_CHANGE
  STAGE_CHANGE
  CALL_LOGGED
  FOLLOWUP_LOGGED
  FOLLOWUP_COMPLETED
  TASK_CREATED
  QUOTATION_CREATED
  QUOTATION_SENT
  LEAD_ASSIGNED
  LEAD_CONVERTED
  FILE_ATTACHED
  EMAIL_SENT
  WHATSAPP_SENT
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

enum CallOutcome {
  CONNECTED
  NOT_REACHABLE
  BUSY
  INTERESTED
  FOLLOW_UP_REQUIRED
  QUOTATION_REQUESTED
  CONVERTED
  WRONG_NUMBER
}

enum CallProvider {
  MANUAL
  TWILIO
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  RESCHEDULED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum ProductCategory {
  VERMICOMPOST
  PROM
  HUMIC_ACID
  ORGANIC_FERTILIZER
  MICRONUTRIENT
  SOIL_CONDITIONER
  BIO_FERTILIZER
  CROP_NUTRITION
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
}

enum NotificationType {
  FOLLOWUP_DUE
  LEAD_ASSIGNED
  QUOTATION_RESPONSE
  TASK_ASSIGNED
  STAGE_CHANGE
  GENERAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
  WHATSAPP
}

enum FileCategory {
  QUOTATION_PDF
  ATTACHMENT
}

// ============================================================
// AUTH (Better Auth core models + app fields on User)
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?

  // App-specific fields
  role            Role     @default(SALES_EXECUTIVE)
  phone           String?
  territoryStates String[] @default([])
  isActive        Boolean  @default(true)
  lastLoginAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // App relations
  ownedLeads       Lead[]                 @relation("LeadOwner")
  ownedCustomers   Customer[]             @relation("CustomerOwner")
  calls            Call[]
  followUps        FollowUp[]
  assignedTasks    Task[]                 @relation("TaskAssignee")
  createdTasks     Task[]                 @relation("TaskCreator")
  createdQuotations Quotation[]           @relation("QuotationCreator")
  createdOrders    Order[]                @relation("OrderCreator")
  leadActivities   LeadActivity[]
  pipelineMoves    PipelineStageHistory[]
  uploadedFiles    File[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@index([role])
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ============================================================
// CRM CORE
// ============================================================

model Lead {
  id          String     @id @default(cuid())
  leadNumber  String     @unique
  name        String
  companyName String?
  contactPerson String?
  phone       String
  whatsapp    String?
  altPhone    String?
  email       String?
  state       String
  district    String
  pincode     String?
  address     String?
  source      LeadSource @default(DIRECT_CALL)
  status      LeadStatus @default(NEW)
  customerType CustomerType @default(B2C_FARMER)

  interestedProducts    String?
  expectedQuantity      String?
  expectedMonthlyValue  Decimal? @db.Decimal(12, 2)
  estimatedValue        Decimal? @db.Decimal(12, 2)
  cropInterest          String?
  isGovernmentTender    Boolean  @default(false)
  remarks               String?
  lostReason            String?

  // Phase-2 hooks (free, nullable)
  whatsappOptIn         Boolean?
  leadScore             Int?

  assignedToId String?
  assignedTo   User?   @relation("LeadOwner", fields: [assignedToId], references: [id])

  convertedCustomer Customer? @relation("LeadConversion")
  convertedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipeline   Pipeline?
  activities LeadActivity[]
  calls      Call[]
  followUps  FollowUp[]
  tasks      Task[]
  quotations Quotation[]
  orders     Order[]
  notifications Notification[]
  files      File[]

  @@index([status])
  @@index([state])
  @@index([assignedToId])
  @@index([createdAt])
}

model Pipeline {
  id              String        @id @default(cuid())
  leadId          String        @unique
  lead            Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  stage           PipelineStage @default(NEW_LEAD)
  enteredStageAt  DateTime      @default(now())
  expectedCloseDate DateTime?
  probability     Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  stageHistory PipelineStageHistory[]

  @@index([stage])
}

model PipelineStageHistory {
  id         String        @id @default(cuid())
  pipelineId String
  pipeline   Pipeline      @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  fromStage  PipelineStage?
  toStage    PipelineStage
  movedById  String
  movedBy    User          @relation(fields: [movedById], references: [id])
  movedAt    DateTime      @default(now())

  @@index([pipelineId])
}

model LeadActivity {
  id          String       @id @default(cuid())
  leadId      String
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  type        ActivityType
  description String
  metadata    Json?
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([leadId, createdAt])
}

model Call {
  id              String        @id @default(cuid())
  leadId          String?
  lead            Lead?         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  direction       CallDirection @default(OUTBOUND)
  outcome         CallOutcome?
  durationSeconds Int?
  notes           String?
  calledAt        DateTime      @default(now())
  createdAt       DateTime      @default(now())

  // Twilio Voice (in-browser calling) fields — null/MANUAL for Sprint 2 manual logs
  provider        CallProvider  @default(MANUAL)
  providerCallSid String?       @unique
  providerStatus  String?
  recordingUrl    String?
  recordingSid    String?
  fromNumber      String?
  toNumber        String?

  @@index([leadId])
  @@index([customerId])
  @@index([userId, calledAt])
}

model FollowUp {
  id             String         @id @default(cuid())
  leadId         String?
  lead           Lead?          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  customerId     String?
  customer       Customer?      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedToId   String
  assignedTo     User           @relation(fields: [assignedToId], references: [id])
  dueAt          DateTime
  priority       TaskPriority   @default(MEDIUM)
  status         FollowUpStatus @default(PENDING)
  notes          String?
  completedAt    DateTime?
  reminderSentAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([assignedToId, dueAt])
  @@index([status])
}

model Task {
  id                String       @id @default(cuid())
  title             String
  description       String?
  assignedToId      String
  assignedTo        User         @relation("TaskAssignee", fields: [assignedToId], references: [id])
  assignedById      String
  assignedBy        User         @relation("TaskCreator", fields: [assignedById], references: [id])
  relatedLeadId     String?
  relatedLead       Lead?        @relation(fields: [relatedLeadId], references: [id], onDelete: SetNull)
  relatedCustomerId String?
  relatedCustomer   Customer?    @relation(fields: [relatedCustomerId], references: [id], onDelete: SetNull)
  dueAt             DateTime?
  priority          TaskPriority @default(MEDIUM)
  status            TaskStatus   @default(OPEN)
  completedAt       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([assignedToId, status])
}

model Customer {
  id             String       @id @default(cuid())
  customerNumber String       @unique
  name           String
  companyName    String?
  contactPerson  String?
  customerType   CustomerType @default(B2C_FARMER)
  phone          String
  whatsapp       String?
  altPhone       String?
  email          String?
  state          String
  district       String
  pincode        String?
  address        String?
  latitude       Float?
  longitude      Float?
  gstNumber      String?
  panNumber      String?

  creditLimit       Decimal? @db.Decimal(12, 2)
  outstandingAmount Decimal  @default(0) @db.Decimal(12, 2)
  annualPurchase    Decimal? @db.Decimal(14, 2)

  // Distributor / Dealer-specific (nullable)
  dealerTier        DealerTier?
  territoryAssigned String?
  annualTargetValue Decimal?    @db.Decimal(14, 2)

  // Phase-2 hooks
  preferredLanguage String?

  assignedToId String?
  assignedTo   User?   @relation("CustomerOwner", fields: [assignedToId], references: [id])

  sourceLeadId String? @unique
  sourceLead   Lead?   @relation("LeadConversion", fields: [sourceLeadId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calls         Call[]
  followUps     FollowUp[]
  tasks         Task[]
  quotations    Quotation[]
  orders        Order[]
  notifications Notification[]
  files         File[]

  @@index([customerType])
  @@index([state])
  @@index([assignedToId])
}

model Product {
  id               String          @id @default(cuid())
  sku              String          @unique
  name             String
  category         ProductCategory
  hsnCode          String?
  description      String?
  unit             String
  packSize         String?
  mrp              Decimal         @db.Decimal(12, 2)
  dealerPrice      Decimal?        @db.Decimal(12, 2)
  distributorPrice Decimal?        @db.Decimal(12, 2)
  gstPercent       Decimal         @default(5) @db.Decimal(5, 2)
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  quotationItems QuotationItem[]

  @@index([category])
}

model Quotation {
  id                String          @id @default(cuid())
  quotationNumber   String          @unique
  leadId            String?
  lead              Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  customerId        String?
  customer          Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User            @relation("QuotationCreator", fields: [createdById], references: [id])
  status            QuotationStatus @default(DRAFT)
  validUntil        DateTime?
  subtotal          Decimal         @default(0) @db.Decimal(14, 2)
  discountPercent   Decimal         @default(0) @db.Decimal(5, 2)
  discountAmount    Decimal         @default(0) @db.Decimal(14, 2)
  freightAmount     Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(14, 2)
  totalAmount       Decimal         @default(0) @db.Decimal(14, 2)
  termsAndConditions String?
  notes             String?
  sentAt            DateTime?
  respondedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  items QuotationItem[]
  order Order?
  files File[]

  @@index([status])
  @@index([customerId])
  @@index([createdById])
}

model QuotationItem {
  id              String    @id @default(cuid())
  quotationId     String
  quotation       Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  description     String?
  quantity        Decimal   @db.Decimal(12, 2)
  unitPrice       Decimal   @db.Decimal(12, 2)
  discountPercent Decimal   @default(0) @db.Decimal(5, 2)
  lineTotal       Decimal   @db.Decimal(14, 2)

  @@index([quotationId])
}

model Order {
  id            String        @id @default(cuid())
  orderNumber   String        @unique
  quotationId   String?       @unique
  quotation     Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  leadId        String?
  lead          Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)
  totalAmount   Decimal       @db.Decimal(14, 2)
  status        OrderStatus   @default(CONFIRMED)
  paymentStatus PaymentStatus @default(PENDING)
  // Denormalized from customer for fast territory-revenue dashboard queries
  state         String
  district      String
  orderedAt     DateTime      @default(now())
  deliveredAt   DateTime?
  createdById   String
  createdBy     User          @relation("OrderCreator", fields: [createdById], references: [id])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([state])
  @@index([orderedAt])
}

model Notification {
  id                String              @id @default(cuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              NotificationType
  channel           NotificationChannel @default(IN_APP)
  title             String
  body              String?
  relatedLeadId     String?
  relatedLead       Lead?               @relation(fields: [relatedLeadId], references: [id], onDelete: Cascade)
  relatedCustomerId String?
  relatedCustomer   Customer?           @relation(fields: [relatedCustomerId], references: [id], onDelete: Cascade)
  isRead            Boolean             @default(false)
  createdAt         DateTime            @default(now())

  @@index([userId, isRead])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}

model File {
  id                 String       @id @default(cuid())
  fileName           String
  filePath           String
  mimeType           String
  sizeBytes          Int
  category           FileCategory @default(ATTACHMENT)
  relatedLeadId      String?
  relatedLead        Lead?        @relation(fields: [relatedLeadId], references: [id], onDelete: Cascade)
  relatedCustomerId  String?
  relatedCustomer    Customer?    @relation(fields: [relatedCustomerId], references: [id], onDelete: Cascade)
  relatedQuotationId String?
  relatedQuotation   Quotation?   @relation(fields: [relatedQuotationId], references: [id], onDelete: Cascade)
  uploadedById       String
  uploadedBy         User         @relation(fields: [uploadedById], references: [id])
  createdAt          DateTime     @default(now())

  @@index([relatedQuotationId])
}
