# Local PostgreSQL (portable install, see scripts/pg-start.ps1)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/urvar_crm?schema=public"

# Better Auth
BETTER_AUTH_SECRET="change-me"
# BETTER_AUTH_URL isn't read by our own code, but the better-auth package
# itself reads it directly as its server-side baseURL — omitting it logs a
# "Base URL is not set" warning and can break callback/redirect URLs.
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Twilio Voice (in-browser calling) — from the Twilio console:
# Account SID + Auth Token: Console > Account dashboard
# API Key SID/Secret: Console > Account > API keys & tokens (create a Standard key)
# TwiML App SID: Console > Voice > TwiML Apps (Voice request URL = {APP_URL}/api/voice/twiml)
# Caller ID: a Voice-capable Twilio number, in E.164 format (e.g. +14155551234)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_API_KEY_SID=""
TWILIO_API_KEY_SECRET=""
TWILIO_TWIML_APP_SID=""
TWILIO_CALLER_ID=""

# Local directory where downloaded call recordings (.mp3) are stored.
CALL_RECORDINGS_DIR="./storage/call-recordings"
